// Flying Fish Scuba School ERP — normalized PostgreSQL schema (Supabase)
// Auth is handled by Supabase Auth (auth.users). The `User` model here is the
// public-schema profile row (same id as auth.users.id), created via a DB
// trigger — see prisma/sql/auth_trigger.sql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  FOUNDER
  MANAGER
  INSTRUCTOR
  MARKETING
  ACCOUNTANT
}

enum SwimmingStatus {
  NON_SWIMMER
  WEAK_SWIMMER
  COMPETENT_SWIMMER
  STRONG_SWIMMER
}

enum CertificationLevel {
  NONE
  OPEN_WATER
  ADVANCED_OPEN_WATER
  RESCUE
  DIVEMASTER
  INSTRUCTOR
  OTHER
}

enum ActivityType {
  BOAT_RIDE
  SHORT_DIVE
  LONG_DIVE
  LONG_DOUBLE_DIVE
  FUN_DIVE
  DIVE_GOA
  SEI
  FLYING_FISH
  PADI_OWD
  SSI_OWD
  PADI_AOW
  SSI_AOW
  EANX
  RESCUE
  REACT_RIGHT
  PPB
  ADVANCED_ADVENTURE
  WRECK_SPECIALTY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  ONLINE_GATEWAY
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum CertificationAgency {
  PADI
  SSI
  OTHER
}

enum CertificationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PENDING_CARD
  ISSUED
}

enum TransactionType {
  REVENUE
  EXPENSE
}

enum ExpenseCategory {
  BOAT
  TEMPO
  FREELANCER
  SNACKS
  SALARY
  MARKETING
  EQUIPMENT
  MAINTENANCE
  OTHER
}

enum RevenueCategory {
  BOOKING
  COURSE
  MERCHANDISE
  OTHER
}

enum ReviewSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReviewReplyStatus {
  PENDING
  REPLIED
  NOT_NEEDED
}

enum SocialPlatform {
  INSTAGRAM
  YOUTUBE
  FACEBOOK
  LINKEDIN
  EXPLURGER
  GOOGLE_BUSINESS
}

enum FollowUpType {
  REPEAT_GUEST
  BIRTHDAY
  CERTIFICATION_REMINDER
  GENERAL
}

enum FollowUpChannel {
  WHATSAPP
  EMAIL
  CALL
}

enum FollowUpStatus {
  PENDING
  DONE
  SNOOZED
  CANCELLED
}

enum NotificationType {
  UPCOMING_COURSE
  PENDING_PAYMENT
  PENDING_FREELANCER_PAYMENT
  PENDING_CERTIFICATION
  DAILY_REMINDER
  GENERAL
}

enum VendorPaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  BOOKED
  COMPLETED
  LOST
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id            String   @id @db.Uuid
  email         String   @unique
  fullName      String
  phone         String?
  role          UserRole @default(INSTRUCTOR)
  avatarUrl     String?
  isActive      Boolean  @default(true)
  monthlySalary Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookingsAsInstructor Booking[]            @relation("BookingInstructor")
  staffAttendance      StaffAttendance[]
  diveLogsAsInstructor DiveLog[]            @relation("DiveLogInstructor")
  certificationsTaught GuestCertification[] @relation("CertificationInstructor")
  followUpsAssigned    FollowUp[]           @relation("FollowUpAssignee")
  transactionsCreated  FinanceTransaction[] @relation("TransactionCreatedBy")
  reviewsMentioned     GoogleReview[]       @relation("ReviewInstructorMentioned")
  notifications        Notification[]       @relation("NotificationTarget")
  salaryPayments       StaffSalaryPayment[]
  leadsAssigned        Lead[]               @relation("LeadAssignee")
  auditLogs            AuditLog[]           @relation("AuditLogUser")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Guests
// ---------------------------------------------------------------------------

model Guest {
  id                    String             @id @default(uuid()) @db.Uuid
  fullName              String
  phone                 String
  email                 String?
  nationality           String?
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalDeclaration    Boolean            @default(false)
  medicalNotes          String?
  swimmingStatus        SwimmingStatus     @default(COMPETENT_SWIMMER)
  certificationLevel    CertificationLevel @default(NONE)
  previousDives         Int                @default(0)
  dateOfBirth           DateTime?          @db.Date
  source                String?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  bookings          Booking[]
  payments          Payment[]
  certifications    GuestCertification[]
  followUps         FollowUp[]
  reviews           GoogleReview[]       @relation("ReviewGuest")
  snackConsumptions SnackConsumption[]   @relation("SnackConsumptionGuest")
  diveLogGuests     DiveLogGuest[]
  leads             Lead[]

  @@index([phone])
  @@index([email])
  @@index([fullName])
  @@map("guests")
}

// ---------------------------------------------------------------------------
// Operations: dive sites, boats, bookings, payments
// ---------------------------------------------------------------------------

model DiveSite {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  location    String?
  description String?
  createdAt   DateTime @default(now())

  bookings Booking[]
  diveLogs DiveLog[]

  @@map("dive_sites")
}

model Boat {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  vendor    String?
  capacity  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings           Booking[]
  boatSharingEntries BoatSharingEntry[]
  snackConsumptions  SnackConsumption[]
  diveLogs           DiveLog[]

  @@map("boats")
}

model ActivityRate {
  id           String       @id @default(uuid()) @db.Uuid
  activityType ActivityType @unique
  price        Decimal      @default(0) @db.Decimal(10, 2)
  isActive     Boolean      @default(true)
  updatedAt    DateTime     @updatedAt

  @@map("activity_rates")
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  guestId      String        @db.Uuid
  guest        Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  instructorId String?       @db.Uuid
  instructor   User?         @relation("BookingInstructor", fields: [instructorId], references: [id])
  boatId       String?       @db.Uuid
  boat         Boat?         @relation(fields: [boatId], references: [id])
  diveSiteId   String?       @db.Uuid
  diveSite     DiveSite?     @relation(fields: [diveSiteId], references: [id])
  activityType ActivityType
  date         DateTime      @db.Date
  status       BookingStatus @default(PENDING)
  price        Decimal       @default(0) @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments Payment[]

  @@index([date])
  @@index([status])
  @@index([guestId])
  // Dashboard/reports/bookings-list all filter status IN (...) AND date
  // BETWEEN ... together; this composite lets Postgres serve that combined
  // filter with one index scan instead of a bitmap AND of two indexes.
  @@index([status, date])
  // Per-instructor booking lookups (analytics.ts) filter on both together.
  @@index([instructorId, status])
  @@map("bookings")
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  guestId   String        @db.Uuid
  guest     Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  bookingId String?       @db.Uuid
  booking   Booking?      @relation(fields: [bookingId], references: [id])
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(CASH)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  dueDate   DateTime?     @db.Date
  notes     String?
  createdAt DateTime      @default(now())

  @@index([status])
  @@index([guestId])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Boat sharing (replaces the Boat Sharing Excel sheet)
// ---------------------------------------------------------------------------

model BoatSharingEntry {
  id                  String              @id @default(uuid()) @db.Uuid
  date                DateTime            @db.Date
  boatId              String?             @db.Uuid
  boat                Boat?               @relation(fields: [boatId], references: [id])
  boatVendorName      String?
  boatAmount          Decimal             @default(0) @db.Decimal(10, 2)
  tempoAmount         Decimal             @default(0) @db.Decimal(10, 2)
  ffGuests            Int                 @default(0)
  dgGuests            Int                 @default(0)
  seiGuests           Int                 @default(0)
  totalGuests         Int                 @default(0)
  vendorPaymentStatus VendorPaymentStatus @default(PENDING)
  outstandingAmount   Decimal             @default(0) @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  splits         BoatSharingSplit[]
  vendorPayments BoatVendorPayment[]

  @@index([date])
  @@map("boat_sharing_entries")
}

model BoatSharingSplit {
  id         String           @id @default(uuid()) @db.Uuid
  entryId    String           @db.Uuid
  entry      BoatSharingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  partyName  String
  guestCount Int              @default(0)
  amountDue  Decimal          @default(0) @db.Decimal(10, 2)
  amountPaid Decimal          @default(0) @db.Decimal(10, 2)
  status     PaymentStatus    @default(PENDING)

  @@map("boat_sharing_splits")
}

// A running ledger of payments made to the boat/tempo vendor against a
// specific trip's outstanding balance (BoatSharingEntry.outstandingAmount).
model BoatVendorPayment {
  id        String           @id @default(uuid()) @db.Uuid
  entryId   String           @db.Uuid
  entry     BoatSharingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(10, 2)
  method    PaymentMethod    @default(CASH)
  paidAt    DateTime         @default(now())
  notes     String?
  createdAt DateTime         @default(now())

  @@index([entryId])
  @@map("boat_vendor_payments")
}

// ---------------------------------------------------------------------------
// Staff & freelancers
// ---------------------------------------------------------------------------

model StaffAttendance {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  @@unique([userId, date])
  @@index([date])
  // Leave Management's monthly leave list and the dashboard's "present
  // today" count both filter status + date range together.
  @@index([status, date])
  @@map("staff_attendance")
}

// One row per staff member per calendar month — the structured counterpart
// to FreelancerPayment, distinct from the loose ExpenseCategory.SALARY
// FinanceTransaction rows (which record the cash-flow side once paid).
model StaffSalaryPayment {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  notes     String?
  createdAt DateTime      @default(now())

  @@unique([userId, month])
  @@index([month])
  @@map("staff_salary_payments")
}

model Freelancer {
  id        String   @id @default(uuid()) @db.Uuid
  fullName  String
  role      String
  phone     String?
  dayRate   Decimal  @default(0) @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  attendance FreelancerAttendance[]
  payments   FreelancerPayment[]

  @@map("freelancers")
}

model FreelancerAttendance {
  id           String           @id @default(uuid()) @db.Uuid
  freelancerId String           @db.Uuid
  freelancer   Freelancer       @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  notes        String?

  @@unique([freelancerId, date])
  @@index([date])
  @@map("freelancer_attendance")
}

model FreelancerPayment {
  id           String        @id @default(uuid()) @db.Uuid
  freelancerId String        @db.Uuid
  freelancer   Freelancer    @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  amount       Decimal       @db.Decimal(10, 2)
  status       PaymentStatus @default(PENDING)
  dueDate      DateTime?     @db.Date
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([status])
  @@map("freelancer_payments")
}

// ---------------------------------------------------------------------------
// Novotel snacks
// ---------------------------------------------------------------------------

// Quick daily box/buffet counter shown on the ops dashboard. Distinct from
// the inventory system below — this is a fast single-number-per-day log,
// not tied to a specific item.
model SnackLog {
  id            String   @id @default(uuid()) @db.Uuid
  date          DateTime @unique @db.Date
  snackBoxCount Int      @default(0)
  buffetCount   Int      @default(0)
  cost          Decimal  @default(0) @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime @default(now())

  @@map("snack_logs")
}

model SnackItem {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  unit         String
  costPerUnit  Decimal  @default(0) @db.Decimal(10, 2)
  currentStock Int      @default(0)
  reorderLevel Int      @default(10)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  purchases    SnackPurchase[]
  consumptions SnackConsumption[]

  @@map("snack_items")
}

// Stock IN. Increments SnackItem.currentStock on create.
model SnackPurchase {
  id        String    @id @default(uuid()) @db.Uuid
  itemId    String    @db.Uuid
  item      SnackItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  quantity  Int
  unitCost  Decimal   @db.Decimal(10, 2)
  totalCost Decimal   @db.Decimal(10, 2)
  vendor    String?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([date])
  // Every purchase row is joined back to its item for display; Postgres
  // doesn't auto-index foreign key columns.
  @@index([itemId])
  @@map("snack_purchases")
}

// Stock OUT. Decrements SnackItem.currentStock on create. guestId/boatId
// capture guest-wise and boat-wise allocation respectively (both optional
// -- a consumption entry can be general, per-guest, or per-boat-trip).
model SnackConsumption {
  id        String    @id @default(uuid()) @db.Uuid
  itemId    String    @db.Uuid
  item      SnackItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  quantity  Int
  guestId   String?   @db.Uuid
  guest     Guest?    @relation("SnackConsumptionGuest", fields: [guestId], references: [id])
  boatId    String?   @db.Uuid
  boat      Boat?     @relation(fields: [boatId], references: [id])
  notes     String?
  createdAt DateTime  @default(now())

  @@index([date])
  // Same as SnackPurchase.itemId -- always joined for display, never
  // indexed automatically.
  @@index([itemId])
  @@map("snack_consumptions")
}

// ---------------------------------------------------------------------------
// Dive logs
// ---------------------------------------------------------------------------

model DiveLog {
  id             String    @id @default(uuid()) @db.Uuid
  date           DateTime  @db.Date
  diveSiteId     String?   @db.Uuid
  diveSite       DiveSite? @relation(fields: [diveSiteId], references: [id])
  boatId         String?   @db.Uuid
  boat           Boat?     @relation(fields: [boatId], references: [id])
  instructorId   String?   @db.Uuid
  instructor     User?     @relation("DiveLogInstructor", fields: [instructorId], references: [id])
  entryTime      DateTime?
  exitTime       DateTime?
  bottomTimeMin  Int?
  maxDepth       Float?
  visibility     Int?
  current        String?
  weather        String?
  temperature    Float?
  equipmentUsed  String?
  cylinderType   String?
  weightsUsedKg  Float?
  marineLifeSeen String?
  problems       String?
  photoUrls      String[]  @default([])
  notes          String?
  createdAt      DateTime  @default(now())

  guests DiveLogGuest[]

  @@index([date])
  // The Dive Logs list page filters by any combination of these three FKs;
  // Postgres can combine single-column indexes with a bitmap AND, and each
  // one is also independently useful for the "most visited sites" /
  // per-instructor groupBy queries.
  @@index([diveSiteId])
  @@index([instructorId])
  @@index([boatId])
  @@map("dive_logs")
}

// Guest-wise join -- a dive log can have multiple guests aboard.
model DiveLogGuest {
  id        String  @id @default(uuid()) @db.Uuid
  diveLogId String  @db.Uuid
  diveLog   DiveLog @relation(fields: [diveLogId], references: [id], onDelete: Cascade)
  guestId   String  @db.Uuid
  guest     Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([diveLogId, guestId])
  @@map("dive_log_guests")
}

// ---------------------------------------------------------------------------
// Certifications
// ---------------------------------------------------------------------------

model CertificationCourse {
  id     String              @id @default(uuid()) @db.Uuid
  name   String
  agency CertificationAgency
  track  String?
  price  Decimal             @default(0) @db.Decimal(10, 2)

  certifications GuestCertification[]

  @@unique([name, agency])
  @@map("certification_courses")
}

model GuestCertification {
  id                      String              @id @default(uuid()) @db.Uuid
  guestId                 String              @db.Uuid
  guest                   Guest               @relation(fields: [guestId], references: [id], onDelete: Cascade)
  courseId                String              @db.Uuid
  course                  CertificationCourse @relation(fields: [courseId], references: [id])
  instructorId            String?             @db.Uuid
  instructor              User?               @relation("CertificationInstructor", fields: [instructorId], references: [id])
  progress                Int                 @default(0)
  status                  CertificationStatus @default(NOT_STARTED)
  theoryCompletedAt       DateTime?           @db.Date
  poolCompletedAt         DateTime?           @db.Date
  openWaterDivesCompleted Int                 @default(0)
  openWaterDivesRequired  Int                 @default(4)
  examPassedAt            DateTime?           @db.Date
  certificateNumber       String?
  startDate               DateTime?           @db.Date
  completionDate          DateTime?           @db.Date
  issueDate               DateTime?           @db.Date
  notes                   String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([status])
  @@map("guest_certifications")
}

// ---------------------------------------------------------------------------
// Finance
// ---------------------------------------------------------------------------

model FinanceTransaction {
  id                 String           @id @default(uuid()) @db.Uuid
  type               TransactionType
  expenseCategory    ExpenseCategory?
  revenueCategory    RevenueCategory?
  amount             Decimal          @db.Decimal(10, 2)
  date               DateTime         @db.Date
  description        String?
  guestId            String?          @db.Uuid
  bookingId          String?          @db.Uuid
  boatSharingEntryId String?          @db.Uuid
  freelancerId       String?          @db.Uuid
  createdById        String?          @db.Uuid
  createdBy          User?            @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime         @default(now())

  @@index([date])
  @@index([type])
  // By far the most common query shape across the dashboard, finance page,
  // and reports: type (REVENUE/EXPENSE) filtered within a date range.
  @@index([type, date])
  @@map("finance_transactions")
}

// ---------------------------------------------------------------------------
// Google reviews & social media
// ---------------------------------------------------------------------------

model GoogleReview {
  id                    String            @id @default(uuid()) @db.Uuid
  reviewerName          String
  guestId               String?           @db.Uuid
  guest                 Guest?            @relation("ReviewGuest", fields: [guestId], references: [id])
  rating                Int
  reviewText            String?
  reviewDate            DateTime          @db.Date
  replyStatus           ReviewReplyStatus @default(PENDING)
  instructorMentionedId String?           @db.Uuid
  instructorMentioned   User?             @relation("ReviewInstructorMentioned", fields: [instructorMentionedId], references: [id])
  sentiment             ReviewSentiment?
  createdAt             DateTime          @default(now())

  @@index([reviewDate])
  // The dashboard's "pending replies" count and the Reviews page filter
  // both query by replyStatus.
  @@index([replyStatus])
  @@map("google_reviews")
}

model SocialMediaPost {
  id             String         @id @default(uuid()) @db.Uuid
  platform       SocialPlatform
  postDate       DateTime       @db.Date
  url            String?
  caption        String?
  isReel         Boolean        @default(false)
  views          Int            @default(0)
  likes          Int            @default(0)
  comments       Int            @default(0)
  shares         Int            @default(0)
  saves          Int            @default(0)
  reach          Int            @default(0)
  leadsGenerated Int            @default(0)
  createdAt      DateTime       @default(now())

  @@index([platform, postDate])
  @@map("social_media_posts")
}

// Point-in-time follower count per platform, used for monthly growth charts
// (follower count isn't a per-post metric, so it's tracked separately).
model SocialFollowerSnapshot {
  id        String         @id @default(uuid()) @db.Uuid
  platform  SocialPlatform
  date      DateTime       @db.Date
  followers Int

  @@unique([platform, date])
  @@map("social_follower_snapshots")
}

// ---------------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------------

model FollowUp {
  id           String          @id @default(uuid()) @db.Uuid
  guestId      String          @db.Uuid
  guest        Guest           @relation(fields: [guestId], references: [id], onDelete: Cascade)
  type         FollowUpType
  channel      FollowUpChannel @default(WHATSAPP)
  dueDate      DateTime        @db.Date
  status       FollowUpStatus  @default(PENDING)
  assignedToId String?         @db.Uuid
  assignedTo   User?           @relation("FollowUpAssignee", fields: [assignedToId], references: [id])
  notes        String?
  createdAt    DateTime        @default(now())

  @@index([dueDate])
  @@index([status])
  @@map("follow_ups")
}

// Pipeline lead, distinct from Guest -- a Lead represents a prospect before
// they've made a booking. Once they book, link guestId to the resulting
// Guest record (created separately via the Guests module) and move the
// stage to BOOKED/COMPLETED.
model Lead {
  id               String    @id @default(uuid()) @db.Uuid
  fullName         String
  phone            String
  email            String?
  source           String?
  stage            LeadStage @default(NEW)
  assignedToId     String?   @db.Uuid
  assignedTo       User?     @relation("LeadAssignee", fields: [assignedToId], references: [id])
  followUpAt       DateTime?
  isRepeatCustomer Boolean   @default(false)
  referredById     String?   @db.Uuid
  referredBy       Lead?     @relation("LeadReferral", fields: [referredById], references: [id])
  referrals        Lead[]    @relation("LeadReferral")
  guestId          String?   @db.Uuid
  guest            Guest?    @relation(fields: [guestId], references: [id])
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([stage])
  @@index([followUpAt])
  // The CRM leads list filters by source and by assigned staff.
  @@index([source])
  @@index([assignedToId])
  @@map("leads")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  type         NotificationType
  title        String
  message      String
  targetUserId String?          @db.Uuid
  targetUser   User?            @relation("NotificationTarget", fields: [targetUserId], references: [id])
  targetRole   UserRole?
  isRead       Boolean          @default(false)
  entityType   String?
  entityId     String?
  createdAt    DateTime         @default(now())

  @@index([targetUserId, isRead])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Season & daily ops
// ---------------------------------------------------------------------------

model Season {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false)

  @@map("seasons")
}

model DailyOpsLog {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @unique @db.Date
  weather      String?
  visibility   Int?
  seaCondition String?
  notes        String?

  @@map("daily_ops_logs")
}

// ---------------------------------------------------------------------------
// Settings
// ---------------------------------------------------------------------------

// Singleton -- application code always reads/updates the first (only) row.
model CompanySettings {
  id                           String   @id @default(uuid()) @db.Uuid
  companyName                  String   @default("Flying Fish Scuba School")
  logoUrl                      String?
  address                      String?
  gstNumber                    String?
  phone                        String?
  email                        String?
  emailNotificationsEnabled    Boolean  @default(true)
  whatsappNotificationsEnabled Boolean  @default(true)
  updatedAt                    DateTime @updatedAt

  @@map("company_settings")
}

// Equipment rental pricing (Settings > Pricing > Rental). Activity pricing
// already lives in ActivityRate; course pricing on CertificationCourse.price.
model RentalItem {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  dailyRate Decimal  @default(0) @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("rental_items")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid
  user       User?       @relation("AuditLogUser", fields: [userId], references: [id])
  action     AuditAction
  entityType String
  entityId   String?
  summary    String
  createdAt  DateTime    @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}
