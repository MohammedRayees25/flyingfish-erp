DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR_DATABASE_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR_DATABASE_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Project Settings -> API -> "anon public" key. Newer Supabase dashboards
# label this "Publishable key" instead — either variable name works, the
# app reads NEXT_PUBLIC_SUPABASE_ANON_KEY first and falls back to
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — never expose client-side. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
