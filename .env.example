# --- Supabase Postgres (Prisma) ---
# Pooled connection (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / client ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Default admin bootstrap (optional) ---
# Used by `npm run db:seed` / `npm run db:bootstrap-admin` to ensure a
# working SUPER_ADMIN login always exists. Requires SUPABASE_SERVICE_ROLE_KEY
# above to be set to a real value — skipped otherwise. If DEFAULT_ADMIN_PASSWORD
# is left unset, a random password is generated and printed once.
# DEFAULT_ADMIN_EMAIL="admin@flyingfish.in"
# DEFAULT_ADMIN_PASSWORD=""
